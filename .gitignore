# Python
.venv/
__pycache__/

# Generated auth module (rendered at install time)
core/auth.py

# Local environment files (may contain secrets)
.env
*.env
nova.env

# SQLite databases — Nova runtime data must never be committed
nova.db
nexus.db
*.db
*.db.*
*.sqlite
*.sqlite3

# Nova Portable Workspace — private runtime directories
# Listed defensively so a stray cp/rsync into the repo does not get staged.
data/
NovaData/
NovaPortable/
backups/
exports/
memory-packs/
logs/

# Backups
*.backup

# Temp
*.save
